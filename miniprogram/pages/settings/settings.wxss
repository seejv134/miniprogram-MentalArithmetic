.settings {
  padding: var(--space-xl) var(--space-xl) var(--space-7xl);
  min-height: 100vh;
  box-sizing: border-box;
  /* 晨雾蓝到珍珠白的渐变，营造流体感 */
  background: var(--bg-gradient-breathing);
  background-size: 400% 400%;
  animation: breathing var(--duration-bg) ease infinite;
  font-family: var(--font-family);
}

/* 毛玻璃卡片 */
.card {
  /* 核心：毛玻璃效果 (Glassmorphism) */
  background: var(--glass-bg-default);
  backdrop-filter: var(--blur-md);
  -webkit-backdrop-filter: var(--blur-md);
  border: 1px solid var(--glass-border-strong);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-xl);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--shadow-glass);
  transition: all var(--duration-fast) ease;
}

.card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-xl) var(--space-2xl);
  gap: var(--space-lg);
}

.card__header-main {
  flex: 1;
  min-width: 0;
  border-radius: var(--radius-sm);
  padding: var(--space-sm);
  margin: -12rpx;
  transition: background-color var(--duration-fast) ease;
}

/* 悬浮反馈：柔和的白色高光 */
.card__header-main--hover {
  background-color: var(--glass-bg-subtle);
}

.card__switch {
  flex-shrink: 0;
  /* 稍微缩小一点开关，让它显得更精致 */
  transform: scale(0.9);
}

.card__title-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.card__title {
  font-size: var(--text-lg);
  font-weight: 400; /* 降低字重，增加优雅感 */
  color: var(--color-text-title);
}

.card__level-tag {
  font-size: var(--text-xs);
  padding: 6rpx var(--space-lg);
  border-radius: var(--radius-md);
  background: var(--color-chip-bg);
  color: var(--color-text-secondary);
  font-weight: 300;
}

.range-preview--header {
  display: block;
  margin-top: var(--space-sm);
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  font-weight: 300;
  word-break: break-all;
}

.card__body {
  border-top: 1px solid var(--glass-border);
  padding: var(--space-lg) var(--space-2xl) var(--space-xl);
}

.card__body--no-header {
  border-top: none;
  padding-top: var(--space-xl);
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--glass-border-hairline);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: var(--text-md);
  color: var(--color-text-body);
  font-weight: 300;
}

/* 分段控制器：毛玻璃风格 */
.seg-ctrl {
  display: flex;
  background: var(--glass-bg-subtle);
  border: 1px solid var(--glass-border-strong);
  border-radius: var(--radius-md);
  overflow: hidden;
  padding: 4rpx;
}

.seg-ctrl__item {
  font-size: var(--text-base);
  padding: var(--space-sm) var(--space-xl);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition: all var(--duration-fast) ease;
}

.seg-ctrl__item--active {
  background: var(--glass-bg-intense);
  color: var(--color-primary);
  box-shadow: 0 4rpx 12rpx var(--color-primary-shadow);
  font-weight: 400;
}

.seg-ctrl__item--hover:not(.seg-ctrl__item--active) {
  background-color: var(--glass-bg-medium);
}

/* 自定义范围输入：柔和的输入框 */
.custom-range {
  padding: var(--space-md) 0;
}

.custom-range__row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.custom-range__label {
  font-size: var(--text-base);
  color: var(--color-text-body);
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 300;
}

.custom-range__input {
  flex: 1;
  height: 72rpx;
  background: var(--glass-bg-medium);
  border: 1px solid var(--glass-border-intense);
  border-radius: var(--radius-sm);
  padding: 0 var(--space-lg);
  font-size: var(--text-md);
  color: var(--color-text-title);
  text-align: center;
  transition: all var(--duration-fast) ease;
}

.custom-range__input:focus {
  background: var(--glass-bg-intense);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx var(--color-primary-shadow);
}

.custom-range__sep {
  font-size: var(--text-base);
  color: var(--color-text-disabled);
}

/* 错误提示和红框：莫兰迪红 */
.has-error .custom-range__input,
.has-error .seg-ctrl {
  border-color: var(--color-error-soft-border);
  background-color: var(--color-error-soft-bg);
}

.error-tip {
  font-size: var(--text-sm);
  color: var(--color-error);
  margin-top: var(--space-sm);
  margin-bottom: var(--space-sm);
  font-weight: 300;
}

/* 保存按钮：悬浮毛玻璃胶囊 */
.save-btn {
  position: fixed;
  bottom: var(--space-4xl);
  left: var(--space-4xl);
  right: var(--space-4xl);
  background: var(--glass-bg-strong);
  backdrop-filter: var(--blur-lg);
  -webkit-backdrop-filter: var(--blur-lg);
  border: 1px solid var(--glass-border-intense);
  color: var(--color-text-body);
  font-size: var(--text-lg);
  font-weight: 400;
  text-align: center;
  padding: var(--space-xl) 0;
  border-radius: var(--radius-pill);
  box-shadow: 0 12rpx 32rpx var(--shadow-glass-strong);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.save-btn--hover {
  transform: scale(0.96);
  background: var(--glass-bg-intense);
  box-shadow: 0 6rpx 16rpx var(--shadow-glass);
}