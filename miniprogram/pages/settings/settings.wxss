.settings {
  padding: 24rpx 28rpx 120rpx;
  min-height: 100vh;
  background: #F5F7FA;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  gap: 24rpx;
}

.card__header-main {
  flex: 1;
  min-width: 0;
  border-radius: 12rpx;
}

/* 与 WeUI cell 一致：用 hover-class 做按下反馈，避免依赖 :active 整页重绘 */
.card__header-main--hover {
  background-color: rgba(0, 0, 0, 0.05);
}

.card__switch {
  flex-shrink: 0;
}

.card__title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.range-preview--header {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6B7280;
  line-height: 1.45;
  font-weight: 400;
  word-break: break-all;
}

.card__title-row--stack {
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
}

.card__level-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #EEEEEE;
  color: #999999;
}

.card__level-tag--on {
  background: #E3F0FF;
  color: #4A90E2;
}

.card__body {
  border-top: 1rpx solid #F0F0F0;
  padding: 12rpx 32rpx 24rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.form-row:last-child {
  border-bottom: none;
}

.card--help {
  margin-bottom: 24rpx;
}

.card__header--help {
  padding: 28rpx 32rpx;
}

.card__header--help:active {
  background: #f8fafc;
}

.card__sub {
  font-size: 24rpx;
  color: #888888;
  font-weight: 400;
}

.card__chevron {
  font-size: 44rpx;
  color: #cccccc;
  line-height: 1;
  padding-left: 16rpx;
}

.form-label {
  font-size: 30rpx;
  color: #444444;
}

.picker-val {
  font-size: 30rpx;
  color: #4A90E2;
  padding: 4rpx 20rpx;
  background: #E3F0FF;
  border-radius: 20rpx;
}

/* 分段控制器 */
.seg-ctrl {
  display: flex;
  border: 2rpx solid #4A90E2;
  border-radius: 20rpx;
  overflow: hidden;
}

.seg-ctrl__item {
  font-size: 26rpx;
  padding: 8rpx 24rpx;
  color: #4A90E2;
  background: #ffffff;
}

.seg-ctrl__item--active {
  background: #4A90E2;
  color: #ffffff;
}

.seg-ctrl__item--hover:not(.seg-ctrl__item--active) {
  background-color: #f0f7ff;
}

.seg-ctrl__item--active.seg-ctrl__item--hover {
  background-color: #3d7fc4;
}

/* 自定义范围输入 */
.custom-range {
  padding: 12rpx 0;
}

.custom-range__row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.custom-range__label {
  font-size: 26rpx;
  color: #666666;
  width: 100rpx;
  flex-shrink: 0;
}

.custom-range__input {
  flex: 1;
  height: 64rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
  text-align: center;
  background: #FAFAFA;
}

.custom-range__sep {
  font-size: 28rpx;
  color: #999999;
}

/* 错误提示和红框 */
.has-error .custom-range__input,
.has-error .seg-ctrl {
  border-color: #FF4D4F;
  background-color: #FFF2F2;
}

.error-tip {
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

/* 保存按钮 */
.save-btn {
  position: fixed;
  bottom: 48rpx;
  left: 40rpx;
  right: 40rpx;
  background: #4A90E2;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(74,144,226,0.35);
}

.save-btn--hover {
  background: #3d7fc4;
  box-shadow: 0 6rpx 18rpx rgba(74,144,226,0.3);
}
