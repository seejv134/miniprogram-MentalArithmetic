.settings {
  padding: var(--space-xl) var(--space-xl) var(--space-7xl);
  min-height: 100vh;
  box-sizing: border-box;
  /* 晨雾蓝到珍珠白的渐变，营造流体感 */
  background: var(--bg-gradient-breathing);
  background-size: 400% 400%;
  animation: breathing var(--duration-bg) ease infinite;
  font-family: var(--font-family);
}

/* 毛玻璃卡片 */
.card {
  /* 核心：毛玻璃效果 (Glassmorphism) */
  background: var(--glass-bg-default);
  backdrop-filter: var(--blur-md);
  -webkit-backdrop-filter: var(--blur-md);
  border: 1px solid var(--glass-border-strong);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-xl);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--shadow-glass);
  transition: all var(--duration-fast) ease;
}

.card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-xl) var(--space-2xl);
  gap: var(--space-lg);
}

.card__header-main {
  flex: 1;
  min-width: 0;
  border-radius: var(--radius-sm);
  padding: var(--space-sm);
  margin: -12rpx;
  transition: background-color var(--duration-fast) ease;
}

/* 悬浮反馈：柔和的白色高光 */
.card__header-main--hover {
  background-color: var(--glass-bg-subtle);
}

.card__switch {
  flex-shrink: 0;
  /* 稍微缩小一点开关，让它显得更精致 */
  transform: scale(0.9);
}

.card__title-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.card__title {
  font-size: var(--text-lg);
  font-weight: 400; /* 降低字重，增加优雅感 */
  color: var(--color-text-title);
}

.card__level-tag {
  font-size: var(--text-xs);
  padding: 6rpx var(--space-lg);
  border-radius: var(--radius-md);
  background: var(--color-chip-bg);
  color: var(--color-text-secondary);
  font-weight: 300;
}

.range-preview--header {
  display: block;
  margin-top: var(--space-sm);
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  font-weight: 300;
  word-break: break-all;
}

.card__body {
  border-top: 1px solid var(--glass-border);
  padding: var(--space-lg) var(--space-2xl) var(--space-xl);
}

.card__body--no-header {
  border-top: none;
  padding-top: var(--space-xl);
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--glass-border-hairline);
}

.form-row:last-child {
  border-bottom: none;
}

/* 外观卡片内的附加开关行：与主题选择区用轻分隔线区分 */
.theme-picker__extra {
  margin-top: var(--space-lg);
  padding-top: var(--space-xl);
  border-top: 1px solid var(--glass-border-hairline);
  border-bottom: none;
}

.form-label {
  font-size: var(--text-md);
  color: var(--color-text-body);
  font-weight: 300;
}

/* 分段控制器：毛玻璃风格 */
.seg-ctrl {
  display: flex;
  background: var(--glass-bg-subtle);
  border: 1px solid var(--glass-border-strong);
  border-radius: var(--radius-md);
  overflow: hidden;
  padding: 4rpx;
}

.seg-ctrl__item {
  font-size: var(--text-base);
  padding: var(--space-sm) var(--space-xl);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition: all var(--duration-fast) ease;
}

.seg-ctrl__item--active {
  background: var(--glass-bg-intense);
  color: var(--color-primary);
  box-shadow: 0 4rpx 12rpx var(--color-primary-shadow);
  font-weight: 400;
}

.seg-ctrl__item--hover:not(.seg-ctrl__item--active) {
  background-color: var(--glass-bg-medium);
}

/* 自定义范围输入：柔和的输入框 */
.custom-range {
  padding: var(--space-md) 0;
}

.custom-range__row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.custom-range__label {
  font-size: var(--text-base);
  color: var(--color-text-body);
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 300;
}

.custom-range__input {
  flex: 1;
  height: 72rpx;
  background: var(--glass-bg-medium);
  border: 1px solid var(--glass-border-intense);
  border-radius: var(--radius-sm);
  padding: 0 var(--space-lg);
  font-size: var(--text-md);
  color: var(--color-text-title);
  text-align: center;
  transition: all var(--duration-fast) ease;
}

.custom-range__input:focus {
  background: var(--glass-bg-intense);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx var(--color-primary-shadow);
}

.custom-range__sep {
  font-size: var(--text-base);
  color: var(--color-text-disabled);
}

/* 错误提示和红框：莫兰迪红 */
.has-error .custom-range__input,
.has-error .seg-ctrl {
  border-color: var(--color-error-soft-border);
  background-color: var(--color-error-soft-bg);
}

.error-tip {
  font-size: var(--text-sm);
  color: var(--color-error);
  margin-top: var(--space-sm);
  margin-bottom: var(--space-sm);
  font-weight: 300;
}

/* 保存按钮：悬浮毛玻璃胶囊 */
.save-btn {
  position: fixed;
  bottom: var(--space-4xl);
  left: var(--space-4xl);
  right: var(--space-4xl);
  background: var(--glass-bg-strong);
  backdrop-filter: var(--blur-lg);
  -webkit-backdrop-filter: var(--blur-lg);
  border: 1px solid var(--glass-border-intense);
  color: var(--color-text-body);
  font-size: var(--text-lg);
  font-weight: 400;
  text-align: center;
  padding: var(--space-xl) 0;
  border-radius: var(--radius-pill);
  box-shadow: 0 12rpx 32rpx var(--shadow-glass-strong);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.save-btn--hover {
  transform: scale(0.96);
  background: var(--glass-bg-intense);
  box-shadow: 0 6rpx 16rpx var(--shadow-glass);
}

/* ==========================================================
 * 主题切换器
 *   三个缩略 chip 固定各自主题的配色，
 *   不随当前主题变化 —— 让用户直观预览氛围。
 * ========================================================== */
.theme-picker-card {
  overflow: hidden;
}

.theme-picker__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}

.theme-picker__title {
  font-size: var(--text-md);
  color: var(--color-text-body);
  font-weight: 400;
  letter-spacing: 2rpx;
}

.theme-picker__hint {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  font-weight: 300;
  letter-spacing: 1rpx;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-md);
}

.theme-chip {
  position: relative;
  height: 260rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border: 1px solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: transform var(--duration-fast) cubic-bezier(0.25, 0.8, 0.25, 1),
              box-shadow var(--duration-fast) ease,
              border-color var(--duration-fast) ease;
}

.theme-chip--hover {
  transform: scale(0.97);
}

/* 背景光晕：放在 chip 上方的装饰层 */
.theme-chip__aurora {
  position: absolute;
  inset: -40%;
  pointer-events: none;
  opacity: 0.85;
  filter: blur(18rpx);
}

/* 内嵌玻璃小方块：展示毛玻璃质感 */
.theme-chip__glass {
  position: relative;
  align-self: flex-end;
  width: 96rpx;
  height: 60rpx;
  border-radius: 14rpx;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.theme-chip__swatch {
  display: flex;
  gap: 8rpx;
}

.theme-chip__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.theme-chip__label {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.theme-chip__name {
  font-size: var(--text-base);
  font-weight: 500;
  letter-spacing: 2rpx;
}

.theme-chip__desc {
  font-size: var(--text-xs);
  font-weight: 300;
  letter-spacing: 1rpx;
  opacity: 0.72;
}

.theme-chip__check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
}

.theme-chip__check::after {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 5rpx;
  width: 8rpx;
  height: 14rpx;
  border-right: 3rpx solid #1a1a1a;
  border-bottom: 3rpx solid #1a1a1a;
  transform: rotate(45deg);
}

/* ── Chip · 晨雾 Mist ───────────────────────────── */
.theme-chip--mist {
  background: linear-gradient(135deg, #E0EAFC 0%, #CFDEF3 50%, #E8F0FE 100%);
}
.theme-chip--mist .theme-chip__aurora {
  background: radial-gradient(circle at 25% 20%, rgba(74, 144, 226, 0.38), transparent 55%),
              radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.9), transparent 50%);
}
.theme-chip--mist .theme-chip__glass {
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(255, 255, 255, 0.85);
}
.theme-chip--mist .theme-chip__dot--1 { background: #4A90E2; }
.theme-chip--mist .theme-chip__dot--2 { background: rgba(74, 144, 226, 0.5); }
.theme-chip--mist .theme-chip__dot--3 { background: #FFFFFF; box-shadow: inset 0 0 0 1rpx rgba(74, 144, 226, 0.3); }
.theme-chip--mist .theme-chip__name { color: #2D3748; }
.theme-chip--mist .theme-chip__desc { color: #4A5568; }

/* ── Chip · 暮色琥珀 Amber ───────────────────────── */
.theme-chip--amber {
  background: linear-gradient(135deg, #2A1710 0%, #1A0F0A 35%, #3A2414 70%, #1F1409 100%);
}
.theme-chip--amber .theme-chip__aurora {
  background: radial-gradient(circle at 30% 25%, rgba(232, 184, 109, 0.45), transparent 50%),
              radial-gradient(circle at 80% 90%, rgba(180, 90, 50, 0.35), transparent 55%);
}
.theme-chip--amber .theme-chip__glass {
  background: rgba(58, 38, 22, 0.55);
  border: 1px solid rgba(232, 184, 109, 0.45);
  box-shadow: 0 0 12rpx rgba(232, 184, 109, 0.15);
}
.theme-chip--amber .theme-chip__dot--1 { background: #E8B86D; box-shadow: 0 0 8rpx rgba(232, 184, 109, 0.6); }
.theme-chip--amber .theme-chip__dot--2 { background: #B5812D; }
.theme-chip--amber .theme-chip__dot--3 { background: #F5E6CB; }
.theme-chip--amber .theme-chip__name { color: #F5E6CB; }
.theme-chip--amber .theme-chip__desc { color: #B69973; }

/* ── Chip · 霓虹赛博 Cyber ───────────────────────── */
.theme-chip--cyber {
  background: linear-gradient(135deg, #0A0B2E 0%, #1A0636 40%, #06112E 70%, #280A32 100%);
}
.theme-chip--cyber .theme-chip__aurora {
  background: radial-gradient(circle at 20% 80%, rgba(0, 229, 255, 0.5), transparent 50%),
              radial-gradient(circle at 85% 20%, rgba(255, 77, 147, 0.55), transparent 50%);
}
.theme-chip--cyber .theme-chip__glass {
  background: rgba(14, 22, 48, 0.65);
  border: 1px solid rgba(0, 229, 255, 0.55);
  box-shadow: 0 0 16rpx rgba(0, 229, 255, 0.3), inset 0 0 8rpx rgba(0, 229, 255, 0.15);
}
.theme-chip--cyber .theme-chip__dot--1 { background: #00E5FF; box-shadow: 0 0 10rpx rgba(0, 229, 255, 0.9); }
.theme-chip--cyber .theme-chip__dot--2 { background: #FF4D93; box-shadow: 0 0 10rpx rgba(255, 77, 147, 0.8); }
.theme-chip--cyber .theme-chip__dot--3 { background: #45F0B0; box-shadow: 0 0 10rpx rgba(69, 240, 176, 0.8); }
.theme-chip--cyber .theme-chip__name { color: #EAF4FF; }
.theme-chip--cyber .theme-chip__desc { color: #7E90BF; }

/* ── 选中态：用当前主题的 primary 作高亮边框 ──────── */
.theme-chip--active {
  border-color: rgba(255, 255, 255, 0.85);
  box-shadow: 0 0 0 2rpx var(--color-primary),
              0 12rpx 32rpx var(--shadow-glass-strong);
  transform: translateY(-2rpx);
}

.theme-chip--mist.theme-chip--active {
  box-shadow: 0 0 0 2rpx #4A90E2,
              0 12rpx 32rpx rgba(74, 144, 226, 0.2);
}
.theme-chip--amber.theme-chip--active {
  box-shadow: 0 0 0 2rpx #E8B86D,
              0 12rpx 32rpx rgba(232, 184, 109, 0.25);
}
.theme-chip--cyber.theme-chip--active {
  box-shadow: 0 0 0 2rpx #00E5FF,
              0 12rpx 32rpx rgba(0, 229, 255, 0.35);
}