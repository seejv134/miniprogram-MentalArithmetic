<view class="settings theme-{{theme}}" wx:if="{{settings}}">

  <!-- 主题切换 -->
  <view class="card theme-picker-card">
    <view class="card__body card__body--no-header">
      <view class="theme-picker__head">
        <text class="theme-picker__title">外观</text>
        <text class="theme-picker__hint">选择你喜欢的氛围</text>
      </view>
      <view class="theme-grid">
        <view
          wx:for="{{themeOptions}}"
          wx:key="id"
          class="theme-chip theme-chip--{{item.id}} {{theme === item.id ? 'theme-chip--active' : ''}}"
          hover-class="theme-chip--hover"
          hover-start-time="20"
          hover-stay-time="120"
          bindtap="onThemeTap"
          data-theme="{{item.id}}"
        >
          <view class="theme-chip__aurora"></view>
          <view class="theme-chip__glass">
            <view class="theme-chip__swatch">
              <view class="theme-chip__dot theme-chip__dot--1"></view>
              <view class="theme-chip__dot theme-chip__dot--2"></view>
              <view class="theme-chip__dot theme-chip__dot--3"></view>
            </view>
          </view>
          <view class="theme-chip__label">
            <text class="theme-chip__name">{{item.name}}</text>
            <text class="theme-chip__desc">{{item.desc}}</text>
          </view>
          <view class="theme-chip__check" wx:if="{{theme === item.id}}"></view>
        </view>
      </view>

      <view class="form-row theme-picker__extra">
        <text class="form-label">我是英语达人</text>
        <switch
          class="card__switch"
          checked="{{settings.feedback.englishMode}}"
          bindchange="onToggleEnglishMode"
          catchtap="stopProp"
          color="{{switchColor}}"
        />
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card__body card__body--no-header">
      <view class="form-row">
        <text class="form-label">音效</text>
        <switch
          class="card__switch"
          checked="{{settings.feedback.soundEnabled}}"
          bindchange="onToggleFeedbackSound"
          catchtap="stopProp"
          color="{{switchColor}}"
        />
      </view>
      <view class="form-row">
        <text class="form-label">震动</text>
        <switch
          class="card__switch"
          checked="{{settings.feedback.vibrationEnabled}}"
          bindchange="onToggleFeedbackVibration"
          catchtap="stopProp"
          color="{{switchColor}}"
        />
      </view>
    </view>
  </view>

  <!-- 加法 -->
  <view class="card">
    <view class="card__header">
      <view
        class="card__header-main"
        bindtap="onToggleCard"
        data-type="addition"
        hover-class="card__header-main--hover"
        hover-start-time="50"
        hover-stay-time="100"
      >
        <view class="card__title-row">
          <text class="card__title">加法</text>
          <text class="card__level-tag" wx:if="{{!settings.addition.enabled}}">已关闭</text>
        </view>
        <text class="range-preview range-preview--header">{{previewAddition}}</text>
      </view>
      <switch
        class="card__switch"
        checked="{{settings.addition.enabled}}"
        bindchange="onToggleEnabled"
        data-type="addition"
        catchtap="stopProp"
        color="{{switchColor}}"
      />
    </view>

    <view class="card__body" hidden="{{expandedCard !== 'addition'}}">
      <view class="custom-range {{errorField === 'addition_range' ? 'has-error' : ''}}">
        <view class="custom-range__row">
          <text class="custom-range__label">加数范围</text>
          <input class="custom-range__input" type="number" value="{{settings.addition.custom.min}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="addition" data-field="min" placeholder="最小值"/>
          <text class="custom-range__sep">~</text>
          <input class="custom-range__input" type="number" value="{{settings.addition.custom.max}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="addition" data-field="max" placeholder="最大值"/>
        </view>
        <view class="error-tip" wx:if="{{errorField === 'addition_range'}}">范围的最小值不能大于最大值</view>
      </view>

      <view class="form-row {{errorField === 'addition_carryPolicy' ? 'has-error' : ''}}">
        <text class="form-label">进位策略</text>
        <view class="seg-ctrl">
          <view class="seg-ctrl__item {{settings.addition.carryPolicy === 'any' ? 'seg-ctrl__item--active' : ''}}" hover-class="seg-ctrl__item--hover" hover-start-time="50" hover-stay-time="100" bindtap="onCarryPolicy" data-policy="any">不限</view>
          <view class="seg-ctrl__item {{settings.addition.carryPolicy === 'must' ? 'seg-ctrl__item--active' : ''}}" hover-class="seg-ctrl__item--hover" hover-start-time="50" hover-stay-time="100" bindtap="onCarryPolicy" data-policy="must">必须进位</view>
        </view>
      </view>
      <view class="error-tip" wx:if="{{errorField === 'addition_carryPolicy'}}">当前范围无法产生进位，请修改范围或更改进位策略</view>
    </view>
  </view>

  <!-- 减法 -->
  <view class="card">
    <view class="card__header">
      <view
        class="card__header-main"
        bindtap="onToggleCard"
        data-type="subtraction"
        hover-class="card__header-main--hover"
        hover-start-time="50"
        hover-stay-time="100"
      >
        <view class="card__title-row">
          <text class="card__title">减法</text>
          <text class="card__level-tag" wx:if="{{!settings.subtraction.enabled}}">已关闭</text>
        </view>
        <text class="range-preview range-preview--header">{{previewSubtraction}}</text>
      </view>
      <switch
        class="card__switch"
        checked="{{settings.subtraction.enabled}}"
        bindchange="onToggleEnabled"
        data-type="subtraction"
        catchtap="stopProp"
        color="{{switchColor}}"
      />
    </view>

    <view class="card__body" hidden="{{expandedCard !== 'subtraction'}}">
      <view class="custom-range {{errorField === 'subtraction_range' ? 'has-error' : ''}}">
        <view class="custom-range__row">
          <text class="custom-range__label">减数与差范围</text>
          <input class="custom-range__input" type="number" value="{{settings.subtraction.custom.min}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="subtraction" data-field="min" placeholder="最小值"/>
          <text class="custom-range__sep">~</text>
          <input class="custom-range__input" type="number" value="{{settings.subtraction.custom.max}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="subtraction" data-field="max" placeholder="最大值"/>
        </view>
        <view class="error-tip" wx:if="{{errorField === 'subtraction_range'}}">范围的最小值不能大于最大值</view>
      </view>

      <view class="form-row {{errorField === 'subtraction_borrowPolicy' ? 'has-error' : ''}}">
        <text class="form-label">退位策略</text>
        <view class="seg-ctrl">
          <view class="seg-ctrl__item {{settings.subtraction.borrowPolicy === 'any' ? 'seg-ctrl__item--active' : ''}}" hover-class="seg-ctrl__item--hover" hover-start-time="50" hover-stay-time="100" bindtap="onBorrowPolicy" data-policy="any">不限</view>
          <view class="seg-ctrl__item {{settings.subtraction.borrowPolicy === 'must' ? 'seg-ctrl__item--active' : ''}}" hover-class="seg-ctrl__item--hover" hover-start-time="50" hover-stay-time="100" bindtap="onBorrowPolicy" data-policy="must">必须退位</view>
        </view>
      </view>
      <view class="error-tip" wx:if="{{errorField === 'subtraction_borrowPolicy'}}">当前范围无法产生退位，请修改范围或更改退位策略</view>
    </view>
  </view>

  <!-- 乘法 -->
  <view class="card">
    <view class="card__header">
      <view
        class="card__header-main"
        bindtap="onToggleCard"
        data-type="multiplication"
        hover-class="card__header-main--hover"
        hover-start-time="50"
        hover-stay-time="100"
      >
        <view class="card__title-row">
          <text class="card__title">乘法</text>
          <text class="card__level-tag" wx:if="{{!settings.multiplication.enabled}}">已关闭</text>
        </view>
        <text class="range-preview range-preview--header">{{previewMultiplication}}</text>
      </view>
      <switch
        class="card__switch"
        checked="{{settings.multiplication.enabled}}"
        bindchange="onToggleEnabled"
        data-type="multiplication"
        catchtap="stopProp"
        color="{{switchColor}}"
      />
    </view>

    <view class="card__body" hidden="{{expandedCard !== 'multiplication'}}">
      <view class="custom-range {{errorField === 'multiplication_range' ? 'has-error' : ''}}">
        <view class="custom-range__row">
          <text class="custom-range__label">乘数1范围</text>
          <input class="custom-range__input" type="number" value="{{settings.multiplication.custom.min1}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="multiplication" data-field="min1" placeholder="最小值"/>
          <text class="custom-range__sep">~</text>
          <input class="custom-range__input" type="number" value="{{settings.multiplication.custom.max1}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="multiplication" data-field="max1" placeholder="最大值"/>
        </view>
        <view class="custom-range__row">
          <text class="custom-range__label">乘数2范围</text>
          <input class="custom-range__input" type="number" value="{{settings.multiplication.custom.min2}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="multiplication" data-field="min2" placeholder="最小值"/>
          <text class="custom-range__sep">~</text>
          <input class="custom-range__input" type="number" value="{{settings.multiplication.custom.max2}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="multiplication" data-field="max2" placeholder="最大值"/>
        </view>
        <view class="error-tip" wx:if="{{errorField === 'multiplication_range'}}">乘数范围的最小值不能大于最大值</view>
      </view>
    </view>
  </view>

  <!-- 除法 -->
  <view class="card">
    <view class="card__header">
      <view
        class="card__header-main"
        bindtap="onToggleCard"
        data-type="division"
        hover-class="card__header-main--hover"
        hover-start-time="50"
        hover-stay-time="100"
      >
        <view class="card__title-row">
          <text class="card__title">除法</text>
          <text class="card__level-tag" wx:if="{{!settings.division.enabled}}">已关闭</text>
        </view>
        <text class="range-preview range-preview--header">{{previewDivision}}</text>
      </view>
      <switch
        class="card__switch"
        checked="{{settings.division.enabled}}"
        bindchange="onToggleEnabled"
        data-type="division"
        catchtap="stopProp"
        color="{{switchColor}}"
      />
    </view>

    <view class="card__body" hidden="{{expandedCard !== 'division'}}">
      <view class="custom-range {{errorField === 'division_range' ? 'has-error' : ''}}">
        <view class="custom-range__row">
          <text class="custom-range__label">除数范围</text>
          <input class="custom-range__input" type="number" value="{{settings.division.custom.minD}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="division" data-field="minD" placeholder="最小值"/>
          <text class="custom-range__sep">~</text>
          <input class="custom-range__input" type="number" value="{{settings.division.custom.maxD}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="division" data-field="maxD" placeholder="最大值"/>
        </view>
        <view class="custom-range__row">
          <text class="custom-range__label">商范围</text>
          <input class="custom-range__input" type="number" value="{{settings.division.custom.minQ}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="division" data-field="minQ" placeholder="最小值"/>
          <text class="custom-range__sep">~</text>
          <input class="custom-range__input" type="number" value="{{settings.division.custom.maxQ}}" bindinput="onCustomInput" bindblur="onCustomBlur" data-type="division" data-field="maxQ" placeholder="最大值"/>
        </view>
        <view class="error-tip" wx:if="{{errorField === 'division_range'}}">商/除数范围的最小值不能大于最大值</view>
      </view>
    </view>
  </view>

  <view class="save-btn" hover-class="save-btn--hover" hover-start-time="50" hover-stay-time="100" bindtap="onSave">保存设置</view>

</view>
