.practice {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  /* 晨雾蓝到珍珠白的渐变，营造流体感 */
  background: var(--bg-gradient-breathing);
  background-size: 400% 400%;
  animation: breathing var(--duration-bg) ease infinite;
  font-family: var(--font-family);
  color: var(--color-text-body);
}

/* 顶部栏：极简透明 */
.practice__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xl) var(--space-3xl);
  /* 移除原有的白色背景和阴影，融入环境 */
}

.practice__score {
  font-size: var(--text-md);
  font-weight: 400;
  color: var(--color-text-secondary);
  letter-spacing: 4rpx;
}

.practice__settings-btn {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
  padding: var(--space-sm) var(--space-xl);
  /* 按钮也采用轻微的毛玻璃效果 */
  background: var(--glass-bg-subtle);
  backdrop-filter: var(--blur-sm);
  -webkit-backdrop-filter: var(--blur-sm);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-xl);
  transition: all var(--duration-fast) ease;
}

.practice__settings-btn:active {
  transform: scale(0.95);
  background: var(--glass-bg-medium);
}

/* 主体：极致留白 */
.practice__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-3xl) var(--space-6xl); /* 底部留出呼吸空间 */
}

/* 题目：优雅排版 */
.practice__question {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-6xl);
  gap: var(--space-lg); /* 增加符号与数字之间的呼吸感 */
}

.practice__num,
.practice__operator,
.practice__eq,
.practice__blank {
  font-size: var(--text-3xl); /* 适中、克制的字号 */
  font-weight: 300; /* 优雅的细体 */
  color: var(--color-text-title);
  line-height: 1;
}

.practice__operator {
  color: var(--color-text-secondary); /* 符号颜色稍微弱化 */
}

.practice__eq {
  color: var(--color-text-disabled);
}

.practice__blank {
  color: var(--color-primary);
  font-weight: 400;
  min-width: 60rpx;
  text-align: center;
  /* 用柔和的下划线代替生硬的问号，或者保留问号加下划线 */
  border-bottom: 2px solid var(--color-primary-underline);
  padding-bottom: var(--space-sm);
}

/* 选项：毛玻璃键盘 */
.practice__options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
  width: 100%;
  max-width: 560rpx;
}

.practice__option {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 核心：毛玻璃效果 (Glassmorphism) */
  background: var(--glass-bg-default);
  backdrop-filter: var(--blur-md);
  -webkit-backdrop-filter: var(--blur-md);
  border: 1px solid var(--glass-border-strong);
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx var(--shadow-glass);
  transition: all var(--duration-normal) cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* 涟漪反馈：点击时像按在水面上一样轻微下沉 */
.practice__option:active {
  transform: scale(0.96);
  background: var(--glass-bg-strong);
  box-shadow: none;
}

/* 答对状态：柔和的莫兰迪绿 */
.practice__option--correct {
  background: var(--color-success-bg);
  border-color: var(--color-success-border);
}

/* 答错状态：柔和的莫兰迪红 */
.practice__option--wrong {
  background: var(--color-error-bg);
  border-color: var(--color-error-border);
}

/* 未选中/变暗状态 */
.practice__option--dim {
  opacity: 0.3;
  transform: scale(0.98);
}

.practice__option-text {
  font-size: var(--text-2xl);
  font-weight: 400; /* 配合整体的轻盈感 */
  color: var(--color-text-body);
}

.practice__option--correct .practice__option-text {
  color: var(--color-success);
}

.practice__option--wrong .practice__option-text {
  color: var(--color-error);
}

/* 无题目状态：同样保持极简和毛玻璃质感 */
.practice__empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-lg);
  padding: var(--space-4xl);
}

.practice__empty-text {
  font-size: var(--text-lg);
  font-weight: 300;
  color: var(--color-text-body);
}

.practice__empty-hint {
  font-size: var(--text-base);
  font-weight: 300;
  color: var(--color-text-disabled);
}

.practice__go-settings {
  margin-top: var(--space-2xl);
  padding: var(--space-lg) var(--space-5xl);
  background: var(--glass-bg-medium);
  backdrop-filter: var(--blur-sm);
  -webkit-backdrop-filter: var(--blur-sm);
  border: 1px solid var(--glass-border-intense);
  color: var(--color-text-body);
  border-radius: var(--radius-pill);
  font-size: var(--text-md);
  font-weight: 400;
  box-shadow: 0 8rpx 24rpx var(--shadow-glass-md);
  transition: all var(--duration-fast) ease;
}

.practice__go-settings:active {
  transform: scale(0.96);
  background: var(--glass-bg-strong);
}

/* ═════════════════════════════════════════════
 * 英语达人模式：题目竖排、选项单列，字号整体降档
 * 仅在根元素挂 .practice--en 时生效，不影响数字模式
 * ═════════════════════════════════════════════ */
.practice--en .practice__question {
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: var(--space-5xl);
  text-align: center;
}

.practice--en .practice__num,
.practice--en .practice__blank {
  font-size: var(--text-xl-plus);
  line-height: 1.35;
  word-break: break-word;
  max-width: 100%;
}

.practice--en .practice__operator,
.practice--en .practice__eq {
  font-size: var(--text-lg);
  line-height: 1.35;
  word-break: break-word;
  max-width: 100%;
}

.practice--en .practice__blank {
  min-width: var(--size-practice-en-blank-min-width);
  padding: 0 var(--space-md) var(--space-sm);
}

.practice--en .practice__options {
  grid-template-columns: 1fr;
  max-width: var(--size-practice-en-options-max-width);
  gap: var(--space-lg);
}

.practice--en .practice__option {
  height: auto;
  min-height: var(--size-practice-en-option-min-height);
  padding: var(--space-md) var(--space-xl);
}

.practice--en .practice__option-text {
  font-size: var(--text-xl);
  line-height: 1.4;
  text-align: center;
  word-break: break-word;
}