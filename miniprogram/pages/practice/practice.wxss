/* 动画：流体呼吸背景 */
@keyframes breathing {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.practice {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  /* 晨雾蓝到珍珠白的渐变，营造流体感 */
  background: linear-gradient(-45deg, #E0EAFC, #CFDEF3, #E8F0FE, #F5F7FA);
  background-size: 400% 400%;
  animation: breathing 15s ease infinite;
  font-family: 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #4A5568;
}

/* 顶部栏：极简透明 */
.practice__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 48rpx;
  /* 移除原有的白色背景和阴影，融入环境 */
}

.practice__score {
  font-size: 32rpx;
  font-weight: 400;
  color: #718096;
  letter-spacing: 4rpx;
}

.practice__settings-btn {
  font-size: 28rpx;
  color: #718096;
  padding: 12rpx 32rpx;
  /* 按钮也采用轻微的毛玻璃效果 */
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.practice__settings-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.5);
}

/* 主体：极致留白 */
.practice__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx 120rpx; /* 底部留出呼吸空间 */
}

/* 题目：优雅排版 */
.practice__question {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 120rpx;
  gap: 24rpx; /* 增加符号与数字之间的呼吸感 */
}

.practice__num,
.practice__operator,
.practice__eq,
.practice__blank {
  font-size: 72rpx; /* 适中、克制的字号 */
  font-weight: 300; /* 优雅的细体 */
  color: #2D3748;
  line-height: 1;
}

.practice__operator {
  color: #718096; /* 符号颜色稍微弱化 */
}

.practice__eq {
  color: #A0AEC0;
}

.practice__blank {
  color: #4A90E2;
  font-weight: 400;
  min-width: 60rpx;
  text-align: center;
  /* 用柔和的下划线代替生硬的问号，或者保留问号加下划线 */
  border-bottom: 2px solid rgba(74, 144, 226, 0.3);
  padding-bottom: 8rpx;
}

/* 选项：毛玻璃键盘 */
.practice__options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  width: 100%;
  max-width: 560rpx;
}

.practice__option {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 核心：毛玻璃效果 (Glassmorphism) */
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(113, 128, 150, 0.05);
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* 涟漪反馈：点击时像按在水面上一样轻微下沉 */
.practice__option:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 16rpx rgba(113, 128, 150, 0.02);
}

/* 答对状态：柔和的莫兰迪绿 */
.practice__option--correct {
  background: rgba(198, 246, 213, 0.6);
  border-color: rgba(72, 187, 120, 0.4);
}

/* 答错状态：柔和的莫兰迪红 */
.practice__option--wrong {
  background: rgba(254, 215, 215, 0.6);
  border-color: rgba(245, 101, 101, 0.4);
}

/* 未选中/变暗状态 */
.practice__option--dim {
  opacity: 0.3;
  transform: scale(0.98);
}

.practice__option-text {
  font-size: 56rpx;
  font-weight: 400; /* 配合整体的轻盈感 */
  color: #4A5568;
}

.practice__option--correct .practice__option-text {
  color: #2F855A;
}

.practice__option--wrong .practice__option-text {
  color: #C53030;
}

/* 无题目状态：同样保持极简和毛玻璃质感 */
.practice__empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 60rpx;
}

.practice__empty-text {
  font-size: 36rpx;
  font-weight: 300;
  color: #4A5568;
}

.practice__empty-hint {
  font-size: 28rpx;
  font-weight: 300;
  color: #A0AEC0;
}

.practice__go-settings {
  margin-top: 40rpx;
  padding: 24rpx 80rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  color: #4A5568;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: 400;
  box-shadow: 0 8rpx 24rpx rgba(113, 128, 150, 0.08);
  transition: all 0.3s ease;
}

.practice__go-settings:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.7);
}